# ── Required ──────────────────────────────────────────────────────────────────

# Claude API — get yours at console.anthropic.com
ANTHROPIC_API_KEY=

# Notion integration token — create at notion.so/my-integrations
NOTION_TOKEN=

# Notion page/database IDs — printed by `npm run seed` or copy from your DB URLs
NOTION_DAILY_SUMMARIES_PAGE_ID=
NOTION_JOB_TRACKER_DB_ID=

# ── Optional Notion databases ─────────────────────────────────────────────────

# Preferences DB — Notion controls agent behavior (titles, skills, salary, etc.)
# Run `npm run seed` to create this automatically.
# Schema: Setting (title) | Value (text) | Category (select) | Active (checkbox)
NOTION_PREFERENCES_DB_ID=

# Control Panel DB — pause/resume the agent and track runs from Notion
# Schema: Agent Name (title) | Run Agent (checkbox) | Mode (select) | Last Run (date) | Last Run Stats (text)
NOTION_CONTROL_DB_ID=

# ── Job Sources ───────────────────────────────────────────────────────────────

# Adzuna — free tier at developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
