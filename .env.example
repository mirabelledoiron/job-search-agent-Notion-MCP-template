# ── Required ──────────────────────────────────────────────────────────────────

# Claude API (required for job scoring + market summary)
ANTHROPIC_API_KEY=

# Notion integration token (required for writing results)
NOTION_TOKEN=

# Core Notion page/database IDs — printed by `npm run seed`
NOTION_DAILY_SUMMARIES_PAGE_ID=
NOTION_JOB_TRACKER_DB_ID=

# ── Optional Notion databases (Notion-as-Control-Layer) ───────────────────────

# Preferences DB — Notion controls agent behavior (titles, skills, salary, etc.)
# DB schema: Setting (title) | Value (text) | Category (select) | Active (checkbox)
# Supported Setting keys:
#   titles, exclude_titles, skills, locations, target_companies,
#   salary_floor, salary_target_min, salary_target_max, salary_stretch,
#   min_score, industry_target, industry_avoid
# Leave blank to use config.json or built-in defaults
NOTION_PREFERENCES_DB_ID=

# Control Panel DB — pause/resume the agent, track runs, set mode from Notion
# DB schema: Agent Name (title) | Run Agent (checkbox) | Mode (select: daily/test/paused)
#            Last Run (date) | Last Run Stats (text)
# Leave blank to always run in "daily" mode
NOTION_CONTROL_DB_ID=

# ── Human Feedback fields (add manually to your Job Tracker DB) ───────────────
# These are READ by the agent to improve future scoring — no extra env var needed.
# Add these optional columns to your Job Tracker database:
#   Status      — Select   — options: New | Reviewed | Interested | Applied | Ignored
#   Relevant    — Checkbox — mark jobs you found useful / on-target
#   Not Relevant— Checkbox — mark jobs that were noise / off-target
#   Notes       — Text     — freeform feedback

# ── Job Sources ───────────────────────────────────────────────────────────────

# Adzuna (free tier — register at developer.adzuna.com)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Dice job search API key
DICE_API_KEY=
